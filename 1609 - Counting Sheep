#include<stdio.h>
int main()
{
    int t,n,i,j,k;
    scanf("%d",&t);
    for(i=0; i<t; i++)
    {
        int count=0;
        scanf("%d",&n);
        int sheep[n];
        for(j=0; j<n; j++)
        {
            scanf("%d",&sheep[j]);

        }
        for(j=0; j<n; j++)
        {
            for(k=j+1; k<n; k++)
            {
                if (sheep[j]==sheep[k])
                {
                    count++;
                    break;
                }
            }
        }
        printf("%d\n",n-count);
    }
    return 0;
}
